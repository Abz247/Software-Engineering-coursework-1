extends layout

block content
    if listing
        .detail-layout
            .listing-image
                if listing.image_url
                    img(src=listing.image_url alt=listing.title)
                else
                    img(src='https://via.placeholder.com/800x500?text=No+Image' alt='No image available')

            .listing-info
                h2= listing.title
                p
                    strong Price:
                    |  £#{listing.price}
                p
                    strong Seller:
                    |  #{listing.seller || listing.username || 'Unknown seller'}
                p
                    strong Category:
                    |  #{listing.category || 'Uncategorised'}
                p
                    strong Size:
                    |  #{listing.size || 'Not specified'}
                p
                    strong Condition:
                    |  #{listing.condition || 'Not specified'}
                p
                    strong Status:
                    |  #{listing.status || 'Available'}
                if listing.description
                    p
                        strong Description:
                    p= listing.description

                .actions
                    if user && Number(user.id) === Number(listing.user_id)
                        a.button(href='/listings/edit/' + listing.id) Edit listing
                        form(action='/listings/delete/' + listing.id, method='POST')
                            button.button.danger(type='submit') Delete listing
                    a.button.secondary(href='/listings') Back to listings
    else
        .form-card
            h2 Listing not found
            p The requested item could not be found.
            a.button.secondary(href='/listings') Back to listings