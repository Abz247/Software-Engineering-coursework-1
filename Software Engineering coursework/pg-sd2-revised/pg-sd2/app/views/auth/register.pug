extends ../layout

block content
  .auth-wrapper
    .auth-card
      h1 Create Your Account
      p.auth-subtitle Join ClosetSwap and start swapping sustainable fashion.

      form(action="/register" method="POST")
        .form-group
          label(for="username") Username
          input#username(type="text" name="username" placeholder="e.g. fashionista99" value=(username || '') required minlength="3" maxlength="50")

        .form-group
          label(for="email") Email Address
          input#email(type="email" name="email" placeholder="you@roehampton.ac.uk" value=(email || '') required)

        .form-group
          label(for="password") Password
          input#password(type="password" name="password" placeholder="Min 8 chars, 1 uppercase, 1 number" required minlength="8")

        .form-group
          label(for="confirmPassword") Confirm Password
          input#confirmPassword(type="password" name="confirmPassword" placeholder="Re-enter your password" required)

        button.btn.btn-primary(type="submit") Register

      p.auth-footer Already have an account? 
        a(href="/login") Log in here
