extends ../layout

block content
  .profile-header
    .profile-avatar= profileUser.username.charAt(0).toUpperCase()
    .profile-details
      h1= profileUser.username
      p.profile-email= profileUser.email
      p.profile-joined= "Member since " + new Date(profileUser.created_at).toLocaleDateString('en-GB')
      p.profile-count= listingCount + (listingCount !== 1 ? " listings" : " listing") + " posted"

  h2= profileUser.username + "'s Listings"

  if listings && listings.length
    .listings-grid
      each item in listings
        .listing-card
          if item.image_url
            img.listing-img(src=item.image_url alt=item.title)
          .listing-card-body
            h3.listing-title= item.title
            p.listing-price= "£" + parseFloat(item.price).toFixed(2)
            p.listing-meta= item.size + " · " + item.condition
            if item.category
              span.listing-tag= item.category
            if item.status === 'sold'
              span.listing-tag.tag-sold Sold
            a.btn.btn-sm(href="/listings/" + item.id) View Details
  else
    p.empty-state This user hasn't listed any items yet.
