extends ../layout

block content
  h1 All Users
  p Browse the ClosetSwap community.

  if users && users.length
    .users-grid
      each u in users
        .user-card
          .user-card-avatar= u.username.charAt(0).toUpperCase()
          .user-card-info
            h3
              a(href="/users/" + u.id)= u.username
            p.user-card-email= u.email
            p.user-card-joined= "Joined " + new Date(u.created_at).toLocaleDateString('en-GB')
  else
    p.empty-state No users have registered yet.
